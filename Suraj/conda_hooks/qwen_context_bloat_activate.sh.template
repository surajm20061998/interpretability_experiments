#!/usr/bin/env bash

# This file is copied into:
#   $CONDA_PREFIX/etc/conda/activate.d/qwen_context_bloat.sh
# by scripts/setup_qwen_context_bloat_env.sh.

export _QCB_PREV_HF_HOME="${HF_HOME-}"
export _QCB_PREV_HF_HUB_CACHE="${HF_HUB_CACHE-}"
export _QCB_PREV_TRANSFORMERS_CACHE="${TRANSFORMERS_CACHE-}"
export _QCB_PREV_MPLCONFIGDIR="${MPLCONFIGDIR-}"
export _QCB_PREV_TOKENIZERS_PARALLELISM="${TOKENIZERS_PARALLELISM-}"
export _QCB_PREV_PYTORCH_ENABLE_MPS_FALLBACK="${PYTORCH_ENABLE_MPS_FALLBACK-}"
export _QCB_PREV_PYTHONPATH="${PYTHONPATH-}"
export _QCB_PREV_QCB_PROJECT_ROOT="${QCB_PROJECT_ROOT-}"
export _QCB_PREV_QCB_ARTIFACT_DIR="${QCB_ARTIFACT_DIR-}"

export QCB_PROJECT_ROOT="__PROJECT_ROOT__"
export QCB_ARTIFACT_DIR="${QCB_PROJECT_ROOT}/artifacts/context_bloat"
export HF_HOME="${QCB_PROJECT_ROOT}/.cache/huggingface"
export HF_HUB_CACHE="${HF_HOME}/hub"
export TRANSFORMERS_CACHE="${HF_HOME}/transformers"
export MPLCONFIGDIR="${QCB_PROJECT_ROOT}/.cache/matplotlib"
export TOKENIZERS_PARALLELISM="false"
export PYTORCH_ENABLE_MPS_FALLBACK="1"

if [ -n "${PYTHONPATH-}" ]; then
  export PYTHONPATH="${QCB_PROJECT_ROOT}:${PYTHONPATH}"
else
  export PYTHONPATH="${QCB_PROJECT_ROOT}"
fi

mkdir -p "${QCB_ARTIFACT_DIR}" "${HF_HUB_CACHE}" "${TRANSFORMERS_CACHE}" "${MPLCONFIGDIR}"

